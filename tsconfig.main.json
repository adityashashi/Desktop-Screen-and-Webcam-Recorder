{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "Node",
        "outDir": "dist",
        "rootDir": "src"
    },
    "include": [
        "src/main/**/*.ts",
        "src/preload/**/*.ts",
        "src/renderer/**/*.d.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}